# ==============================================================================
# REQUIRED — All instances must set these
# ==============================================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_VERIFY_TOKEN=my-custom-verify-token
# App Secret from Meta App Dashboard → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=your-meta-app-secret

# API endpoint auth (shared secret for /api/v1/* endpoint protection)
N8N_WEBHOOK_SECRET=generate-shared-secret-here

# Family members (phone numbers without + prefix)
PARTNER1_PHONE=15551234567
PARTNER2_PHONE=15559876543
# Legacy aliases also supported: JASON_PHONE, ERIN_PHONE

# ==============================================================================
# OPTIONAL — Google Calendar integration
# ==============================================================================

# Calendar IDs
GOOGLE_CALENDAR_PARTNER1_ID=partner1@gmail.com
GOOGLE_CALENDAR_PARTNER2_ID=partner2@gmail.com
GOOGLE_CALENDAR_FAMILY_ID=family123@group.calendar.google.com
# Legacy aliases also supported: GOOGLE_CALENDAR_JASON_ID, GOOGLE_CALENDAR_ERIN_ID

# Google OAuth — for containerized environments (Railway)
# Run setup_calendar.py locally, then paste token.json/credentials.json contents here
GOOGLE_TOKEN_JSON=
GOOGLE_CREDENTIALS_JSON=

# Outlook (work calendar — published ICS feed URL)
OUTLOOK_CALENDAR_ICS_URL=https://outlook.office365.com/owa/calendar/...

# ==============================================================================
# OPTIONAL — Notion integration
# ==============================================================================

NOTION_TOKEN=ntn_...
NOTION_ACTION_ITEMS_DB=abc123...
NOTION_MEAL_PLANS_DB=def456...
NOTION_MEETINGS_DB=ghi789...
NOTION_FAMILY_PROFILE_PAGE=jkl012...
NOTION_BACKLOG_DB=pqr678...
NOTION_GROCERY_HISTORY_DB=stu901...
NOTION_RECIPES_DB=abc123...
NOTION_COOKBOOKS_DB=def456...
NOTION_NUDGE_QUEUE_DB=abc123...
NOTION_CHORES_DB=def456...

# ==============================================================================
# OPTIONAL — YNAB budget integration
# ==============================================================================

YNAB_ACCESS_TOKEN=ynab-token-...
YNAB_BUDGET_ID=last-used

# ==============================================================================
# OPTIONAL — AnyList grocery integration (requires sidecar service)
# ==============================================================================

ANYLIST_EMAIL=jason@example.com
ANYLIST_PASSWORD=...
# For Docker Compose (NUC): http://anylist-sidecar:3000
# For Railway: http://anylist-sidecar.railway.internal:3000
ANYLIST_SIDECAR_URL=http://anylist-sidecar:3000

# ==============================================================================
# OPTIONAL — Other integrations
# ==============================================================================

# Cloudflare R2 (recipe photo storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=family-recipes

# OpenAI (voice note transcription)
OPENAI_API_KEY=sk-...

# ==============================================================================
# DEPLOYMENT — NUC-specific (not needed on Railway)
# ==============================================================================

# Cloudflare Tunnel (public HTTPS for WhatsApp webhooks on NUC)
CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# n8n (only needed if using external n8n instead of in-app scheduler)
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=changeme
N8N_MOMBOT_USER=admin
N8N_MOMBOT_PASSWORD=changeme
N8N_MOMBOT_ENCRYPTION_KEY=generate-random-key-here

# ==============================================================================
# DEPLOYMENT — Railway-specific
# ==============================================================================

# SCHEDULER_ENABLED=true          # Set to "false" to disable in-app APScheduler
# RAILWAY_RUN_UID=0               # Set if volume permissions fail
# PORT=8000                       # Railway sets this automatically
